# WalletConnect Project ID
# Get one at https://cloud.reown.com
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=your_project_id_here

# Upstash Redis (for draft storage)
# Get credentials at https://console.upstash.com
KV_REST_API_URL=your_upstash_redis_url_here
KV_REST_API_TOKEN=your_upstash_redis_token_here

# Tenderly (for transaction simulation)
# Get credentials at https://dashboard.tenderly.co → Settings → Authorization
TENDERLY_ACCESS_KEY=your_tenderly_access_key
TENDERLY_ACCOUNT_SLUG=your_account_slug
TENDERLY_PROJECT_SLUG=your_project_slug

# TwoPhasePermitter signing (server-side only)
# Private key of the trustedSigner wallet configured in the Permitter contract
PERMIT_SIGNER_PRIVATE_KEY=0xyour_private_key_here
